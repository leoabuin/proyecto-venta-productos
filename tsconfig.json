{
    "compilerOptions": {
      "incremental": true,
      "target": "es2020",
      "module": "nodenext",
      "moduleResolution": "nodenext",
      "sourceMap": true,
      "outDir": "./dist",
      "rootDir": "./",
      "esModuleInterop": true,
      "forceConsistentCasingInFileNames": true,
      "strict": true,
      "alwaysStrict": true,
      "skipLibCheck": true,
      "types": ["jest", "node"],
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true
    },
    "include": ["src/**/*", "tests/**/*"],
    "exclude": ["node_modules", "dist"]
}