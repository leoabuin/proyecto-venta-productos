# Configuración del Servidor
PORT=3000
JWT_SECRET=tu_clave_secreta_aqui

# Configuración de Base de Datos (MySQL)
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=contraseña
MYSQLDATABASE=nombre_de_la_db

# Entorno (development / production)
NODE_ENV=development

# Mercado Pago (obtener en https://www.mercadopago.com.ar/developers)
# MP_ACCESS_TOKEN: Token de autenticación para solicitudes al backend
# Formato: APP_USR-XXXXXXXXXXXXXXXX-XXXXXX-XXXXXXXXXXXXXXXXXXXXXXXX
MP_ACCESS_TOKEN=APP_USR-tu_access_token_aqui

# MP_PUBLIC_KEY: Clave pública para integraciones en frontend (opcional si solo usas backend)
# Formato: APP_USR-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
MP_PUBLIC_KEY=APP_USR-tu_public_key_aqui

# MP_WEBHOOK_SECRET: Clave secreta para validar webhooks de Mercado Pago (opcional)
MP_WEBHOOK_SECRET=tu_clave_secreta_webhook

# URLs (usadas para redirect después del pago y webhooks)
FRONTEND_URL=http://localhost:4200
BACKEND_URL=http://localhost:3000

